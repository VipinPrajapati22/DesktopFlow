{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "types": [
            "node",
            "electron"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "renderer/src/*"
            ]
        }
    },
    "include": [
        "renderer/src",
        "electron/main",
        "electron/preload"
    ]
}